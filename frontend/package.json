{
  "name": "mabinogi-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:trade": "npm run dev -w @mabi/trade",
    "dev:admin": "npm run dev -w @mabi/admin",
    "dev:misc": "npm run dev -w @mabi/misc",
    "build": "npm run build -w @mabi/trade && npm run build -w @mabi/admin && npm run build -w @mabi/misc",
    "lint": "eslint .",
    "preview:trade": "npm run preview -w @mabi/trade",
    "preview:admin": "npm run preview -w @mabi/admin",
    "preview:misc": "npm run preview -w @mabi/misc"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "axios": "^1.13.5",
    "lucide-react": "^0.562.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.12.0",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "vite": "^7.2.4"
  }
}
